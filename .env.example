# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# MINIMAX_API_KEY: Optional if supplied by clients/users via settings UI.
MINIMAX_API_KEY=""
MINIMAX_BASE_URL="https://api.minimaxi.com/v1"
MINIMAX_MODEL="MiniMax-M3"

# REQUIRE_CLIENT_API_KEY: Set to "true" to force clients to provide their own API Keys in the UI.
# This strictly blocks anonymous visitors from consuming your backend's GEMINI_API_KEY or other backend credits.
REQUIRE_CLIENT_API_KEY="false"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
